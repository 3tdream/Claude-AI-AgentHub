# Mission Control — Environment Variables
# Copy to .env.local and fill in real values

AGENT_HUB_API_URL=http://localhost:3000/assistant
AGENT_HUB_API_KEY=your-agent-hub-api-key
NEXT_PUBLIC_BASE_URL=http://localhost:3077

# Jira Integration
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# Direct LLM keys (Smart Router + Direct AI execution)
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

AGENT_HUB_LIVE=1

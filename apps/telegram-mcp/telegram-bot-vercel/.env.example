# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: Restrict bot to specific user (Telegram user ID)
ALLOWED_USER_ID=765024895

# Admin user ID for receiving memory warnings
ADMIN_USER_ID=765024895

# Upstash Redis (for production on Vercel)
# Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Groq API Key (for voice transcription with Whisper)
# Get from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key

# FAL.ai API Key (for image generation)
FAL_KEY=your_fal_key

# Bot username (without @)
BOT_USERNAME=MichaelClaudeBot

# Telegram MTProto API credentials (from https://my.telegram.org/apps)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Session string (generated via: npm run generate-session)
TELEGRAM_SESSION=

# Proxy Configuration (Optional - for restricted regions like Russia)
# Supported: SOCKS5 proxy (works with Xray/VLESS, AmneziaWG, Hysteria2)
PROXY_ENABLED=false
PROXY_TYPE=socks5
PROXY_HOST=127.0.0.1
PROXY_PORT=1080
PROXY_USERNAME=
PROXY_PASSWORD=
